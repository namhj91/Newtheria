; Aetheria Script Data File
; UTF-8
; 샘플 목적: 기존 샘플 대사를 삭제하고, 요청된 원문 내용을 로어 친화형 아스테리아/순례자 대화로 재구성한다.
; 문법 시연 목적: scene 캐스팅, 블록 대사, 배경/포커스/스탠딩/파티클/자동 넘김(wait)/선택지(choice, hidden_choice)/점프(jump)/종료(end)를 모두 포함한다.

<event:별바다_재기동_의식>
<scene#0:깊은우주_기동>
{
; scene 기본 캐스팅
actor = goddess
actor = pilgrim
slot_left = goddess
slot_right = pilgrim
focus = goddess
; 최소 cast_json 예시(파서 문법 시연용)
cast_json = {"actors":[{"id":"goddess","name":"아스테리아","layers":["assets/img/goddess.png"]},{"id":"pilgrim","name":"순례자","layers":["assets/img/player.png"]}]}
}
---

<block:배경_기술>
{
; 배경 설명 블록(화자 없이 내레이션성 연출)
bg = assets/img/background.jpg
particle = snow
particle_count = 24
particle_duration = 3400
wait = 2000
}
---

<block:아스테리아_기상>
{
actor = goddess
speaker = 아스테리아
focus = goddess
move_left = goddess
move_right = pilgrim
; 액터별 지정 예시: 현재 slot_left/slot_right 배치와 무관하게 actor id 기준으로 매칭된다.
standing_animation_actor = goddess:float,pilgrim:fade
type_speed = 21
line = 어라, 드디어 눈을 떴네? 안녕, 나의 작은 [[glitch:□□□□□]]. 기분은 좀 어때?
}
---

<block:순례자_혼란>
{
actor = pilgrim
speaker = [[glitch:□□□□□]]
focus = pilgrim
; 인라인 actor 지정 예시(동일 문법): 순례자만 shake, 여신은 float 유지
standing_animation = goddess:float,pilgrim:shake
type_speed = 23
line = …뭐? 윽, 머리야… 여긴 또 어디야. 나 방금 전까지 분명히…
}
---

<block:아스테리아_적응안내>
{
actor = goddess
focus = goddess
type_speed = 21
line = 쉿, 너무 애써서 기억하려고 하지 마. 데이터 로딩… 아, 아니. 영혼이 이 공간의 주파수에 적응하려면 시간이 좀 걸리거든. 갑자기 무리하면 머리만 더 아플 테니까 진정해.
wait = 2000
}
---

<block:순례자_반발>
{
actor = pilgrim
focus = pilgrim
speaker = [[glitch:□□□□□]]
type_speed = 23
line = 데이터? 영혼? 장난해? 지금 내 눈앞에 홀로그램 같은 게 둥둥 떠다니는데 진정이 되겠냐고. 넌 대체 누군데 날 아는 것처럼 말해?
}
---

<block:아스테리아_자기소개>
{
actor = goddess
speaker = 아스테리아
focus = goddess
set_layers = goddess:assets/img/goddess.png
; 좌/우 슬롯 키 + actor 키를 함께 사용할 수 있다.
standing_animation_left = zoom-in
standing_animation_actor = goddess:zoom-in,pilgrim:fade
particle = ember
particle_count = 12
particle_duration = 2800
skip_lock = on
type_speed = 20
line = 나? 나는 아스테리아. 이 끝없이 펼쳐진 별바다를 관리하는 별의 여신이랄까? 뭐, 네 입장에선 새로운 시작 지점에서 안내를 돕는 꽤 친절한 튜토리얼 NPC라고 생각해도 좋아. 아, 스킵 버튼 같은 건 없으니까 내 말 잘 들어야 해?
}
---

<block:순례자_귀환요청>
{
actor = pilgrim
focus = pilgrim
speaker = [[glitch:□□□□□]]
type_speed = 23
line = 여신? NPC? 대체 무슨 미친 소리를 하는 거야… 스킵은 무슨, 지금 당장 여기서 내보내 달라고! 나 집에 가야 해.
}
---

<block:아스테리아_노란빛지시>
{
actor = goddess
focus = goddess
type_speed = 20
line = 집? 흐음… 유감스럽지만 거기로 돌아가는 길은 이미 끊어졌어. 자, 진정하고 내 손끝이 가리키는 곳을 한 번 볼래?
wait = 2000
}
---

<block:손끝_연출>
{
line = (아스테리아가 길고 하얀 손가락을 들어 우주의 한구석을 가리킨다. 수만 개의 은하수 너머, 유독 눈이 시리도록 샛노랗게 타오르는 작은 빛이 일렁인다.)
wait = 2000
}
---

<block:순례자_노란빛반응>
{
actor = pilgrim
focus = pilgrim
speaker = [[glitch:□□□□□]]
type_speed = 23
line = 저건… 뭔데? 쳐다보고 있으니까 왠지 가슴이 꽉 막힌 것처럼 답답해져. 기분이 이상해.
}
---

<block:아스테리아_원세계고지>
{
actor = goddess
focus = goddess
type_speed = 20
line = 당연히 그렇겠지. 수많은 별들이 태어나고 져서 흘러가는 이 별바다에서도, 저긴 유독 눈에 띄는 곳이거든. 넌 저 수많은 별빛들 중에서도 가장 샛노랗게 반짝이던 곳에서 왔어. 아주 작고 위태롭지만, 치열하게 타오르던 네가 살던 세계란다.
}
---

<block:순례자_죽음질문>
{
actor = pilgrim
focus = pilgrim
speaker = [[glitch:□□□□□]]
type_speed = 23
line = 저 노란 빛에서… 내가 왔다고? 그럼 나, 죽은 거야? 진짜로?
choice = 죽음을 인정한다 -> 아스테리아_대기실비유
choice = 현실을 부정한다 -> 아스테리아_대기실비유
hidden_choice = 오히려 좋아.이세계 전생 -> 아스테리아_이세계전생
}
