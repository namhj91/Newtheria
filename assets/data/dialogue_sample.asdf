type_speed = 20
line = 용기 있는 선택이십니다, 순례자님. 새로 태어나 걷게 될 세상에서는 다가오지 않은 슬픔을 미리 두려워하기보다, 매 순간 피어나는 기쁨을 온몸으로 만끽해 주십시오. 그리고 길이 낯설어 외롭거나 잠시 길을 잃는 밤이 오더라도, 하늘을 올려다보십시오. 제가 흩뿌려 둔 별들이 언제나 변함없는 길잡이가 되어 드릴 것입니다.
wait = 1200
}
